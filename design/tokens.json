{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "BigelowDesigns Design System",
  "version": "1.0.0",
  "description": "Editorial · Minimal · Luxury — design tokens for an Architectural Digest-grade affiliate blog",

  "color": {
    "light": {
      "bg": {
        "canvas":   { "value": "#FAF8F4", "description": "Primary page background — warm cream" },
        "surface":  { "value": "#FFFFFF", "description": "Cards, images, elevated surfaces" },
        "elevated": { "value": "#F2EFE8", "description": "Hover on cards, soft elevation" },
        "sunken":   { "value": "#EDE9E0", "description": "Inset boxes (newsletter, FAQ)" }
      },
      "ink": {
        "900": { "value": "#15140F", "description": "Display headings — warm near-black" },
        "800": { "value": "#26251F", "description": "Body text default" },
        "600": { "value": "#4A4842", "description": "Secondary text" },
        "400": { "value": "#827F76", "description": "Metadata, timestamps" },
        "200": { "value": "#CDCBC5", "description": "Borders subtle" },
        "100": { "value": "#E6E5E2", "description": "Dividers" },
        "50":  { "value": "#F7F7F6", "description": "Lightest tint" }
      },
      "accent": {
        "50":  { "value": "#FBF1EA", "description": "Accent backgrounds, badges" },
        "500": { "value": "#B8744A", "description": "Primary CTA — terracotta" },
        "600": { "value": "#8C5634", "description": "CTA hover/pressed" }
      },
      "forest": {
        "700": { "value": "#3A4A3F", "description": "Secondary accent — Editor's Pick" }
      },
      "semantic": {
        "success": { "value": "#3A6B47" },
        "warning": { "value": "#A66B1E" },
        "danger":  { "value": "#94342B" },
        "info":    { "value": "#3D5A7A" }
      }
    },
    "dark": {
      "bg": {
        "canvas":   { "value": "#15140F" },
        "surface":  { "value": "#1F1E18" },
        "elevated": { "value": "#2B2922" },
        "sunken":   { "value": "#100F0B" }
      },
      "ink": {
        "900": { "value": "#F5F2EC" },
        "800": { "value": "#E6E1D4" },
        "600": { "value": "#A8A496" },
        "400": { "value": "#6F6C61" },
        "200": { "value": "#3A382F" },
        "100": { "value": "#2B2922" },
        "50":  { "value": "#1F1E18" }
      },
      "accent": {
        "50":  { "value": "#3A2A1E" },
        "500": { "value": "#D08C5E" },
        "600": { "value": "#E5A47A" }
      },
      "forest": {
        "700": { "value": "#7B9B83" }
      },
      "semantic": {
        "success": { "value": "#7BB28A" },
        "warning": { "value": "#D49B5C" },
        "danger":  { "value": "#D87A6F" },
        "info":    { "value": "#8FAFCC" }
      }
    }
  },

  "typography": {
    "fontFamily": {
      "serif": { "value": "Fraunces, Georgia, serif" },
      "sans":  { "value": "Inter, system-ui, -apple-system, sans-serif" },
      "mono":  { "value": "JetBrains Mono, ui-monospace, monospace" }
    },
    "scale": {
      "display-xl": { "fontFamily": "serif", "fontSize": "72px", "lineHeight": "76px", "fontWeight": 500, "letterSpacing": "-0.04em" },
      "display-lg": { "fontFamily": "serif", "fontSize": "56px", "lineHeight": "60px", "fontWeight": 500, "letterSpacing": "-0.03em" },
      "h1":         { "fontFamily": "serif", "fontSize": "40px", "lineHeight": "48px", "fontWeight": 600, "letterSpacing": "-0.025em" },
      "h2":         { "fontFamily": "serif", "fontSize": "30px", "lineHeight": "38px", "fontWeight": 600, "letterSpacing": "-0.02em" },
      "h3":         { "fontFamily": "serif", "fontSize": "22px", "lineHeight": "30px", "fontWeight": 600, "letterSpacing": "-0.015em" },
      "body-lg":    { "fontFamily": "sans",  "fontSize": "19px", "lineHeight": "32px", "fontWeight": 400, "letterSpacing": "0" },
      "body":       { "fontFamily": "sans",  "fontSize": "16px", "lineHeight": "26px", "fontWeight": 400, "letterSpacing": "0" },
      "body-sm":    { "fontFamily": "sans",  "fontSize": "14px", "lineHeight": "22px", "fontWeight": 400, "letterSpacing": "0" },
      "eyebrow":    { "fontFamily": "sans",  "fontSize": "12px", "lineHeight": "16px", "fontWeight": 600, "letterSpacing": "0.12em", "textTransform": "uppercase" }
    },
    "prose": {
      "maxWidth": "70ch",
      "articleLineHeight": "1.68"
    }
  },

  "spacing": {
    "0":    { "value": "0" },
    "0.5":  { "value": "2px" },
    "1":    { "value": "4px" },
    "2":    { "value": "8px" },
    "3":    { "value": "12px" },
    "4":    { "value": "16px" },
    "6":    { "value": "24px" },
    "8":    { "value": "32px" },
    "12":   { "value": "48px" },
    "16":   { "value": "64px" },
    "20":   { "value": "80px" },
    "24":   { "value": "96px" },
    "32":   { "value": "128px" }
  },

  "radius": {
    "none":    { "value": "0" },
    "sm":      { "value": "4px" },
    "md":      { "value": "6px",  "description": "Buttons, inputs" },
    "lg":      { "value": "8px",  "description": "Cards, boxes" },
    "xl":      { "value": "12px", "description": "Large containers" },
    "2xl":     { "value": "16px", "description": "Hero images, modal" },
    "full":    { "value": "9999px" }
  },

  "shadow": {
    "none": { "value": "none" },
    "xs":   { "value": "0 1px 2px 0 rgba(21,20,15,0.04)" },
    "sm":   { "value": "0 2px 4px -1px rgba(21,20,15,0.05)" },
    "md":   { "value": "0 8px 20px -6px rgba(21,20,15,0.08)", "description": "Card hover lift" },
    "lg":   { "value": "0 12px 32px -8px rgba(21,20,15,0.10)", "description": "Modal, dropdown" },
    "xl":   { "value": "0 24px 60px -12px rgba(21,20,15,0.16)", "description": "Reserved — hero overlays" }
  },

  "breakpoint": {
    "xs": { "value": "0px",    "container": "100%",  "description": "Mobile portrait" },
    "sm": { "value": "640px",  "container": "100%" },
    "md": { "value": "768px",  "container": "720px", "description": "Tablet" },
    "lg": { "value": "1024px", "container": "1024px", "description": "Desktop" },
    "xl": { "value": "1280px", "container": "1200px", "description": "Wide" },
    "2xl":{ "value": "1536px", "container": "1280px", "description": "Locked — no wider" }
  },

  "motion": {
    "duration": {
      "instant":   { "value": "100ms" },
      "quick":     { "value": "180ms" },
      "smooth":    { "value": "280ms" },
      "elegant":   { "value": "480ms" },
      "editorial": { "value": "700ms" }
    },
    "easing": {
      "linear":    { "value": "linear" },
      "out":       { "value": "cubic-bezier(0.32, 0.72, 0, 1)" },
      "in-out":    { "value": "cubic-bezier(0.16, 1, 0.3, 1)" },
      "snappy":    { "value": "cubic-bezier(0.34, 1.56, 0.64, 1)" }
    }
  },

  "z-index": {
    "base":    { "value": 0 },
    "raised":  { "value": 10 },
    "sticky":  { "value": 30 },
    "header":  { "value": 40 },
    "dropdown":{ "value": 50 },
    "modal":   { "value": 60 },
    "toast":   { "value": 70 }
  },

  "a11y": {
    "minTapTarget": { "value": "44px", "description": "WCAG 2.5.5 mobile" },
    "focusRing":    { "value": "2px solid {color.light.accent.500}", "offset": "2px" },
    "contrastTargets": {
      "bodyText":   { "ratio": 4.5, "level": "AA" },
      "largeText":  { "ratio": 3.0, "level": "AA" },
      "uiControls": { "ratio": 3.0, "level": "AA" }
    }
  }
}
